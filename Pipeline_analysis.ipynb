#IMPORTAR LAS TABLAS 

import pandas as pd 
import numpy as np 

#Fact table 
sales = pd.read_excel("Sales_pipeline.xlsx")
print(sales.info())

#Tablas dimensión 
accounts = pd.read_excel("Accounts.xlsx")
products = pd.read_excel("Products.xlsx")
agents = pd.read_excel("sales_Agent.xlsx")

#Confirmar que se cargaron 
print(sales.shape)
print(accounts.shape)
print(products.shape)
print(agents.shape)

#Diagnóstico de columnas 
print("SALES:")
print(sales.info())
print("\nACCOUNTS:")
print(accounts.info())
print("\PRODUCTS:")
print(products.info())
print("\nAGENTS:")
print(agents.info())

#Validar claves para merge 
print("Claves únicas en sales['account']:", sales['account'].nunique())
print("Claves únicas en accounts['account']:", accounts['account'].nunique())

print("\nClaves únicas en sales['product']:", sales['product'].nunique())
print("Claves únicas en products['product']:", products['product'].nunique())

print("\nClaves únicas en sales['sales_agent']:", sales['sales_agent'].nunique())
print("Claves únicas en agents['sales_agent']:", agents['sales_agent'].nunique())

#Diagnóstico de valores que no coinciden 
missing_accounts = set(sales['account'].unique()) - set(accounts['account'].unique())
print("Cuentas en sales que no están en accounts:", missing_accounts)

missing_agents = set(sales['sales_agent'].unique()) - set(agents['sales_agent'].unique())
print("Agentes en sales que no están en agents:", missing_agents)

#Corregir problema con account 

accounts.loc[len(accounts)] = ["Unknown account", "Unknown", 0, 0, 0, "Unknown", "None"]
print(accounts.tail())

#Verificar nuevamente las claves 
missing_accounts = set(sales['account'].unique()) - set(accounts['account'].unique())
print("Cuentas en sales que no están en accounts:", missing_accounts)

missing_agents = set(sales['sales_agent'].unique()) - set(agents['sales_agent'].unique())
print("Agentes en sales que no están en agents:", missing_agents)

#Filtrar los deals 
sales_closed = sales[sales['deal_stage'].isin(['Won', 'Lost'])]
print(sales_closed.shape)

#Merge 

# Unir las dimensiones correctamente
df = (
    sales_closed
    .merge(accounts, on="account", how="left")
    .merge(products, on="product", how="left")
    .merge(agents, on="sales_agent", how="left")
)

print(df.head())
print(df.shape)

#HIPÓTESIS 

#H1 - Hipótesis de la demanda del producto 
#Qué productos tienen mayor demanda y generan más oportunidades de venta?

#Número de oportunidades por producto 
product_demand = df.groupby("product").size().sort_values(ascending=False)
print(f"Número de oportunidades por producto:")
print(product_demand)


#Revenue total por producto
product_revenue = df.groupby("product")["close_value"].sum().sort_values(ascending=False)
print(f"Revenue total por producto:")
print(product_revenue)


#Win rate por product 
win_rate_product = df.groupby("product")["deal_stage"].apply(lambda x:(x=="Won").mean())
print(f"Win rate por producto:")
print(win_rate_product)

#Al realizar un análisis sobre la primer hipótesis todo indica que la empresa sigue una estrategia con:
#Producto de volumne GTX Basic, Producto estrella de ingresos GTX pro y producto premium GTK 500

#H2 - Adopción del producto
#Qué tipo de empresas adoptan cada producto?

#Tamaño de empresa por producto
product_company_size = df.groupby("product")["employees"].mean().sort_values(ascending=False)
print(f"Tamaño de empresa por producto:")
print(product_company_size)

#Revenue promedio de empresa por producto 
product_company_revenue = df.groupby("product")["revenue"].mean().sort_values(ascending=False)
print(f"Revenue promedio de empresa por producto:")
print(product_company_revenue)

#Adopción por el sector
sector_product = pd.crosstab(df["sector"], df["product"])
print(f"Adopción del producto por sector:")
print(sector_product)

#GTX Basic es la el producto con mayor presencia en los sectores y mayores tratos 
#Muchas empresas suelen hacer un upgradate a GTX Pro normalmente esto paso con sectores exigentes en hardware y empresas más grandes
#Para las empresas pequeñas predomina más MG special 
#Para empresas muy grandes es GTK 500 

#Empresas chicas - MG special
#Empresas chicas en crecimiento - GTX Basic 
#Empresas mid - GTX Pro
#Enterprise - GTK 500

#H3 - Rendimiento del equipo de ventas 

#Deals ganados por vendedor 
won_deals_by_rep = (df[df["deal_stage"] == "Won"].groupby("sales_agent").size().sort_values(ascending=False))
print(f"Deals ganados por vendedor")
print(won_deals_by_rep)

#Revenue generado por vendedor 
revenue_by_rep = (df[df["deal_stage"] == "Won"].groupby("sales_agent")["revenue"].sum().sort_values(ascending=False)) 
print(f"Revenue generado por vendedor:")
print(revenue_by_rep)

#Win rate por vendedor 
win_rate_by_rep = (df.groupby("sales_agent")["deal_stage"].apply(lambda x: (x == "Won").mean()).sort_values(ascending=False))
print(f"Win rate por vendedor:")
print(win_rate_by_rep)

#Ticket promedio por vendedor 
avg_ticked_rep = (df[df["deal_stage"] == "Won"].groupby("sales_agent")["revenue"].mean().sort_values(ascending=False))
print(f"Ticket promedio por vendedor:")
print(avg_ticked_rep)

#La empresa maneja vendedores acorde el objetivo del trato ya sean alto volumen de deals, alto revenue o con mayor eficiencia de conversión típico en clientes nuevos

#H4 - Hipótesis por cantidad del trato 
#Cómo es comportamiento de los tratos en cantidad?

# Distribución del tamaño de los deals 
print("Distribución del tamaño de los deals:")
print(df['close_value'].describe())

#Tmaño de deals por empresa
df["deal_size"] = pd.cut(df["close_value"], bins=2, labels=["Small", "Large"])
print(df["deal_size"].value_counts())

#Win rate por tamaño 
win_rate_size = (df.groupby("deal_size")["deal_stage"].apply(lambda x: (x == "Won").mean()))
print(win_rate_size)

#Revenue por tamaño 
revenue_size = (df[df["deal_stage"] == "Won"].groupby("deal_size")["close_value"].sum())
print(revenue_size)

#El negocio depende principalmente de un modelo de alto volumen de transacciones pequeñas, mientras que los tratos grandes tienen un impacto marginal alto
#Los tratos grandes son mas cuidadosos y estrategicos por ende pueden tomar más tiempo en cerrar y puede existir más filtros 

#H4 - Patrones temporales de ventas 
#las ventas tiene un comportamiento por en ciertos momentos?

#Crear columna 
df["close_month"] = df["close_date"].dt.to_period("M")

#Deals cerrrados por mes 
deals_per_month = (df[df["deal_stage"] == "Won"].groupby("close_month").size())
print(f"Deals cerrados por month:")
print(deals_per_month)

#Revenue por mes 
revenue_per_month = (df[df["deal_stage"] == "Won"].groupby("close_month")["close_value"].sum())
print(f"Revenue por mes:")
print(revenue_per_month)

#Win rate por mes
win_rate_month = (df.groupby("close_month")["deal_stage"].apply(lambda x: (x == "Won").mean()))
print(f"Win rate por mes:")
print(win_rate_month)

#El negocio puede tener ventas con comportamientos de ciclos con picos altos y bajadas 
#Puede existir una estrategia de ventas con campñas, objetivos y presión por resultados 
#Existe la posibilidad de que las empresas tengan tratos predecibles 
